{
  "name": "expense-tracker-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start --workspace=server\" \"npm run dev --workspace=client\"",
    "start:server": "npm run start --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "test:server": "npm run test --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
